# PostgreSQL 数据库配置示例
# 注意：请将此文件复制为 .env 并填写实际的数据库连接信息
# 不要将 .env 文件提交到版本控制系统中

# ==================== 基础环境配置 ====================
# 运行环境：development | test | pre | production
NODE_ENV=development

# 前端运行环境：dev | test | pre | prod
REACT_APP_ENV=dev

# ==================== 服务器配置 ====================
# 服务端口
PORT=8001

# ==================== 前端代理配置 ====================
# 后端 API 地址（生产环境应填写完整域名，如：https://api.example.com）
# 开发环境：http://localhost:8080
# 生产环境：https://api.yourdomain.com
REACT_APP_API_URL=http://localhost:8080

# ==================== CORS 配置 ====================
# 允许的前端域名，多个用逗号分隔
# 开发环境：http://localhost:8000
# 生产环境：https://www.yourdomain.com,https://app.yourdomain.com
CORS_ORIGIN=http://localhost:8000

# ==================== JWT 安全配置 ====================
# JWT 密钥（生产环境必须修改为随机生成的强密钥！）
# 生成强密钥示例：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ==================== 数据库连接配置 ====================
# 数据库主机
POSTGRES_HOST=localhost

# 数据库端口
POSTGRES_PORT=5432

# 数据库名称
POSTGRES_DATABASE=betterstats

# 数据库用户名
POSTGRES_USER=postgres

# 数据库密码（生产环境必须修改！）
POSTGRES_PASSWORD=your_password

# ==================== 数据库连接池配置 ====================
# 最小连接数（生产环境建议：5）
POSTGRES_POOL_MIN=2

# 最大连接数（生产环境建议：20）
POSTGRES_POOL_MAX=10

# 连接超时时间（毫秒）
POSTGRES_POOL_TIMEOUT=30000

# ==================== 生产环境数据库 SSL 配置 ====================
# 生产环境数据库是否启用 SSL 连接（true | false）
# 大多数云数据库服务（如 AWS RDS、Heroku Postgres）需要启用 SSL
POSTGRES_SSL=false

# ==================== 其他配置 ====================
# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# 是否启用请求日志（生产环境建议：false）
ENABLE_REQUEST_LOG=true
